        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(ALERTS{slo=\"checkout-api-demo\",severity=\"page\",alertstate=\"firing\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Page alerts firing",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
